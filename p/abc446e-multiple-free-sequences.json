              "type": "code",
              "lang": "",
              "code": "7",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输入 2",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "446 1 1",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 2",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "0",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输入 3",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "1000 784 385",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 3",
          "level": 3,
          "blocks": [
            {
              "type": "code",
