  "format": "logseq",
  "sections": [
    {
      "heading": "题目描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "考虑满足 $0 \\leq x,y \\leq M-1$ 的整数对 $(x, y)$。定义无穷序列 $(s_1, s_2, \\dots)$ 满足以下递推关系：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$s_1 = x$",
          "depth": 2
        },
        {
          "type": "p",
          "html": "$s_2 = y$",
          "depth": 2
        },
        {
          "type": "p",
          "html": "$s_n = A s_{n-1} + B s_{n-2}$ ($n \\geq 3$)",
          "depth": 2
        },
        {
          "type": "p",
          "html": "请问有多少对 $(x, y)$ 使得该序列中不包含任何 $M$ 的倍数？",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输入描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "输入从标准输入中按以下格式给出：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "> $M$ $A$ $B$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$2 \\leq M \\leq 1000$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$0 \\leq A, B \\leq M-1$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "所有输入值均为整数。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输出描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "在一行中输出答案。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "样例",
      "level": 2,
      "blocks": [
        {
          "heading": "输入 1",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "4 1 2",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 1",
          "level": 3,
          "blocks": [
