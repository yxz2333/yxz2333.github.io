    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n; cin >> n;\n\tvar p = vector<ll>();\n\tfa(i, 0, 30)p.pb(1ll << i);\n\tvar Q = priority_queue<ll, vector<ll>, greater<ll>>();\n\tvar vis = set<ll>();\n\tQ.push(0);\n\tint cnt = 0;\n\twhile (Q.size()) {\n\t\tll now = Q.top();\n\t\tQ.pop();\n      \n\t\tif (vis.count(now))continue;\n\t\tvis.insert(now);\n      \n\t\tcnt++;\n\t\tif (cnt == n + 1) {\n\t\t\tcout << now << endl;\n\t\t\treturn;\n\t\t}\n      \n\t\tfor (ll x : p) {\n\t\t\tll wei = (ll)log10(x) + 1;\n\t\t\tll to = now;\n\t\t\tbool ok = 1;\n\t\t\twhile (wei--) {\n\t\t\t\tto *= 10;\n\t\t\t\tif (to > 1e9) {\n\t\t\t\t\tok = 0;\n\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}\n\t\t\tif (!ok)break;\n\t\t\tto += x;\n\t\t\tif (to > 1e9)break;\n\t\t\tQ.push(to);\n\t\t}\n\t}\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
