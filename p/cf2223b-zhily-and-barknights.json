              "depth": 1
            }
          ]
        },
        {
          "heading": "输出",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "5\n665496236\n820778710",
              "depth": 1
            }
          ]
        },
        {
          "heading": "样例说明",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "第一个测试用例：所有 $b$ 为 $1$，$c = (1, 14, 5, 1, 4)$ 固定，逆序对数为 $5$。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "第二个测试用例：$3! = 6$ 种排列，期望值为 $\\frac{4}{6} = \\frac{2}{3}$，模意义下为 $665496236$。",
              "depth": 1
            }
          ]
        }
      ]
    },
    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "heading": "1. 期望拆成对子",
          "level": 3,
          "blocks": [
            {
              "type": "math",
              "latex": "$$E = \\sum_{i<j} \\Pr(c_i > c_j)$$",
              "depth": 1
            }
          ]
        },
        {
          "heading": "2. 对固定 $(i,j)$ 化简概率",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "随机排列下，有序对 $(b'_i,b'_j)$ 均匀取自所有 $(b_k,b_l)\\ (k\\neq l)$，共 $n(n-1)$ 种。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "所以 $$\\Pr(c_i>c_j) = \\frac{\\#\\{(k,l)\\mid a_i b_k > a_j b_l\\}}{n(n-1)}$$",
              "depth": 1
            }
          ]
        },
        {
          "heading": "3. 比值解耦",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "条件变形：$$a_i b_k > a_j b_l \\iff \\frac{a_i}{a_j} > \\frac{b_l}{b_k}$$",
              "depth": 1
            }
          ]
        },
        {
          "heading": "4. 算法",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "预处理：生成所有比值 $\\frac{b_k}{b_l}\\ (k\\neq l)$，排序（浮点/分数均可）。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "对每个 $i<j$，设阈值 $T = \\dfrac{a_i}{a_j}$，二分查找数组中<strong>严格小于 T</strong> 的元素个数 $cnt$。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "$\\displaystyle \\Pr(c_i>c_j) = \\frac{cnt}{n(n-1)}$。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "期望 $E = \\dfrac{\\sum\\limits_{i<j} cnt}{n(n-1)}$，模意义下乘以分母逆元输出。",
              "depth": 1
            }
          ]
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tll n; cin >> n;\n\tvar a = vector<ll>(n + 1);\n\tvar b = vector<ll>(n + 1);\n\tfa(i, 1, n)cin >> a[i];\n\tfa(i, 1, n)cin >> b[i];\n\tif (n == 1) {\n\t\tcout << 0 << endl;\n\t\treturn;\n\t}\n\tvar p = vector<ldb>();\n\tfa(i, 1, n)fa(j, 1, n)if (i != j)p.pb((ldb)b[i] / b[j]);\n\tll tot = 1;\n\tfa(i, 1, n)tot = tot * i % mod;\n\tll tot2 = tot * Math::inv(n, mod) % mod * Math::inv(n - 1, mod) % mod;\n\tsort(all(p));\n\tll ans = 0;\n\tfa(i, 1, n)fa(j, i + 1, n) {\n\t\tldb now = (ldb)a[i] / a[j];\n\t\tll id = lower_bound(all(p), now) - p.begin();\n\t\tll res = id * tot2 % mod;\n\t\tans = (ans + res) % mod;\n\t}\n\tans = ans *  Math::inv(tot, mod) % mod;\n\tcout << ans << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
