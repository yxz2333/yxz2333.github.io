        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "ll dis[N][N];\nvoid solve(int CASE)\n{\n\tll n; cin >> n;\n\tfa(i, 1, n)fa(j, 1, n)cin >> dis[i][j];\n\tvar q = vector<ll>(n + 1);\n\tfa(i, 1, n)cin >> q[i];\n\tvar ans = vector<ll>(n + 2);\n\tvar vis = vector<bool>(n + 1);\n\tfb(p, n, 1) {\n\t\tint k = q[p];\n\t\tvis[k] = 1;\n\t\tfa(i, 1, n)fa(j, 1, n) {\n\t\t\tdis[i][j] = min(dis[i][j], dis[i][k] + dis[k][j]);\n\t\t\tif (vis[i] and vis[j])ans[p] += dis[i][j];\n\t\t}\n\t}\n\tfa(i, 1, n)cout << ans[i] << \" \\n\"[i == n];\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
