  "sections": [
    {
      "heading": "题目描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "高桥君有 $N$ 张卡片。第 $i$ 张卡片上写着整数 $A_i$。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "高桥君会选择一个整数 $K$，然后重复以下操作若干次：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "选择恰好 $K$ 张上面写着互不相同整数的卡片，并吃掉它们（被吃掉的卡片会消失）。",
          "depth": 2
        },
        {
          "type": "p",
          "html": "对于每个 $K=1,2,\\ldots,N$，请你求出最多可以进行多少次上述操作。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输入描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "输入以以下格式从标准输入读入：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "> $N$ $A_1$ $A_2$ $\\ldots$ $A_N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq N \\leq 3 \\times 10^5$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq A_i \\leq N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "输入均为整数",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输出描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "请输出 $N$ 个整数。第 $t$ 个数表示 $K=t$ 时最多可以进行的操作次数。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "样例",
      "level": 2,
      "blocks": [
        {
          "heading": "输入 1",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "3\n2 1 2",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 1",
          "level": 3,
          "blocks": [
