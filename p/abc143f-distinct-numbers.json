              "type": "code",
              "lang": "",
              "code": "3\n1\n0",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输入 2",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "5\n1 2 3 4 5",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 2",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "5\n2\n1\n1\n1",
              "depth": 1
            }
          ]
        },
        {
