    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "<strong>可撤销背包模板题</strong>。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n, m; cin >> n >> m;\n\tvar a = vector<int>(n + 1);\n\tfa(i, 1, n)cin >> a[i];\n\tconst int mod = 10;\n\n\t// 全局背包\n\tvar dp = vector<int>(m + 1);\n\tdp[0] = 1;\n\tfa(i, 1, n)fb(j, m, a[i])dp[j] = (dp[j] + dp[j - a[i]]) % mod;\n\n\tfa(i, 1, n) {\n\t\t// 【撤销 a[i]】\n\t\tfa(j, a[i], m)dp[j] = ((dp[j] - dp[j - a[i]]) % mod + mod) % mod;\n\n\t\tfa(j, 1, m)cout << dp[j];\n\t\tcout << endl;\n\t\t\n\t\t// 【恢复 a[i]】\n\t\tfb(j, m, a[i])dp[j] = (dp[j] + dp[j - a[i]]) % mod;\n\t}\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
