  "sections": [
    {
      "heading": "题目描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "对于一个数列 $X$，定义 $f(X)$ 为：将 $X$ 变为回文数列所需修改的元素个数的最小值。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "给定一个长度为 $N$ 的数列 $A$，请计算所有 $A$ 的<strong>连续</strong>子序列 $X$ 的 $f(X)$ 之和。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输入描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "输入以如下格式从标准输入给出。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "> $N$ $A_1$ $A_2$ $\\dots$ $A_N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "输入均为整数。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\le N \\le 2 \\times 10^5$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\le A_i \\le N$",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输出描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "请输出答案的整数值。",
          "depth": 1
        }
      ]
    },
