              "depth": 1
            }
          ]
        },
        {
          "heading": "样例说明",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "第一个测试用例中，函数如下：",
              "depth": 1
            },
            {
              "type": "p",
              "html": "$f_1(x) = x^2 + 2x - 1$;",
              "depth": 2
            },
            {
              "type": "p",
              "html": "$f_2(x) = -3x^2 - 3$;",
              "depth": 2
            },
            {
              "type": "p",
              "html": "$f_3(x) = -x^2 + 4x - 5$;",
              "depth": 2
            },
            {
              "type": "p",
              "html": "$f_4(x) = x^2 + 2x - 4$。",
              "depth": 2
            },
            {
              "type": "p",
              "html": "函数图像如下：",
              "depth": 1
            },
            {
              "type": "p",
              "html": "![](https://espresso.codeforces.com/168b5d6d822586244824257fcad8369941df3285.png){:height 326, :width 309}",
              "depth": 2
            },
            {
              "type": "p",
              "html": "包含每个函数的最大有序子集如下：",
              "depth": 1
            },
            {
              "type": "p",
              "html": "包含 $f_1$ 的最大有序子集是 $\\{f_1, f_3, f_4\\}$；",
              "depth": 2
            },
            {
              "type": "p",
              "html": "包含 $f_2$ 的最大有序子集是 $\\{f_1, f_2\\}$；",
              "depth": 2
            },
            {
              "type": "p",
              "html": "包含 $f_3$ 的最大有序子集是 $\\{f_1, f_3, f_4\\}$；",
