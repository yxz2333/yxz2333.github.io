            }
          ]
        }
      ]
    },
    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "heading": "建图方式",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "如果两个二次函数 $f(x)$ 和 $g(x)$ 永远不相交，这不仅意味着它们“独立”，还意味着在几何上存在一种<strong>严格的偏序关系</strong>（即：要么 $f$ 永远在 $g$ 上方，要么 $g$ 永远在 $f$ 上方）。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "利用上述性质，建立一个<strong>有向图</strong>：如果 $f_i$ 在 $f_j$ 上方，则连一条 $i \\to j$ 的有向边。",
              "depth": 1
            }
          ]
        },
        {
          "heading": "题目转化 和 答案求解",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "题目要求的“包含 $f_i$ 的最大有序子集”，在图论中等价于求经过节点 $i$ 的<strong>最长链</strong>。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "一个经过点 $i$ 的最长链 = <strong>(以</strong> $i$ <strong>结尾的最长链) + (以</strong> $i$ <strong>开头的最长链) - 1</strong>。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "前者用<strong>拓扑排序</strong>解决，后者用 <strong>dfs+dp (即记忆化搜索)</strong> 解决。",
              "depth": 1
            }
          ]
        },
        {
          "heading": "为何要这样建图？",
          "level": 3,
          "blocks": [
            {
              "heading": "想当然的建图（陷阱）",
              "level": 4,
              "blocks": [
                {
                  "type": "p",
                  "html": "<strong>节点</strong>：每个函数是一个点。",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "<strong>边</strong>：如果函数 $i$ 和函数 $j$ <strong>不相交</strong>（独立），就在它们之间连一条<strong>无向边</strong>。",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "<strong>目标</strong>：找一个最大的子集，使得子集里任意两点都有边相连。",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "<strong>为什么这个思路“死路一条”？</strong>",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "在图论里，这叫做求<strong>最大团</strong>问题。",
                  "depth": 2
                },
                {
                  "type": "p",
                  "html": "在一般图中，求最大团是 <strong>NP-Hard</strong> 的问题。哪怕 $N=50$ 都很难算，而这题 $N=3000$。",
                  "depth": 2
                }
              ]
            },
            {
              "heading": "为什么要那样建图？",
              "level": 4,
              "blocks": [
                {
                  "type": "p",
                  "html": "要解决 NP-Hard 问题，必须利用题目特殊的<strong>性质</strong>。这道题的性质就是：<strong>几何上的传递性</strong>。",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "让我们看看“不相交”在几何上意味着什么：",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "如果抛物线 $A$ 和 $B$ 不相交，必然存在一个<strong>上下关系</strong> —— 要么 $A$ 永远在 $B$ 上方，要么 $B$ 永远在 $A$ 上方。",
                  "depth": 2
                },
                {
                  "type": "p",
                  "html": "<strong>关键在于“传递性”：</strong>",
                  "depth": 1
                },
                {
                  "type": "p",
                  "html": "如果 $A$ 在 $B$ 上方；",
                  "depth": 2
                },
                {
                  "type": "p",
                  "html": "且 $B$ 在 $C$ 上方；",
                  "depth": 2
                },
                {
                  "type": "p",
                  "html": "那么 $A$ <strong>一定</strong> 在 $C$ 上方。",
                  "depth": 2
                },
                {
                  "type": "p",
                  "html": "这意味着，$A, B, C$ 三者两两都不相交。",
                  "depth": 1
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n; cin >> n;\n\tvar p = vector<tuple<ll, ll, ll>>(n + 1);\n\tvar g = vector<vector<int>>(n + 1);\n\tfa(i, 1, n) {\n\t\tll a, b, c; cin >> a >> b >> c;\n\t\tp[i] = { a,b,c };\n\t}\n\tvar deg = vector<int>(n + 1);\n\tfa(i, 1, n)fa(j, i + 1, n) {\n\t\tconst var& [a1, b1, c1] = p[i];\n\t\tconst var& [a2, b2, c2] = p[j];\n\t\tll res = (b1 - b2) * (b1 - b2) - 4 * (a1 - a2) * (c1 - c2);\n\t\tif (res < 0) {\n\t\t\tif (a1 >= a2)g[i].pb(j), deg[j]++;\n\t\t\telse g[j].pb(i), deg[i]++;\n\t\t}\n\t\telse if (a1 == a2 and b1 == b2 and c1 != c2) {\n\t\t\tif (c1 > c2)g[i].pb(j), deg[j]++;\n\t\t\telse g[j].pb(i), deg[i]++;\n\t\t}\n\t}\n\n\tvar Q = queue<pii>();\n\tvar dep = vector<int>(n + 1); // 从 任意一个点 出发到 i 的最远距离（即以 i 结尾的最长链）\n\tfa(i, 1, n)if (!deg[i])Q.push({ i,1 });\n\twhile (Q.size()) {\n\t\tvar[now, nowdep] = Q.front();\n\t\tQ.pop();\n\t\tdep[now] = max(dep[now], nowdep);\n\t\tfor (int to : g[now]) {\n\t\t\tdeg[to]--;\n\t\t\tif (deg[to] == 0)Q.push({ to,nowdep + 1 });\n\t\t}\n\t}\n\n\tvar vis = vector<bool>(n + 1);\n\tvar fdep = vector<int>(n + 1, 1); // 从 i 出发到 任意一个点 的最远距离（即以 i 开头的最长链）\n\tvar dfs = [&](var dfs, int now, int fa)->void {\n\t\tif (vis[now])return;\n\t\tvis[now] = 1;\n\t\tfor (int to : g[now]) {\n\t\t\tif (to == fa)continue;\n\t\t\tdfs(dfs, to, now);\n\t\t\tfdep[now] = max(fdep[now], fdep[to] + 1);\n\t\t}\n\t\t};\n\tfa(i, 1, n)if (!vis[i])dfs(dfs, i, 0);\n\n\t// 到两边的距离相加就是答案\n\tfa(i, 1, n)cout << dep[i] + fdep[i] - 1 << ' ';\n\tcout << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
