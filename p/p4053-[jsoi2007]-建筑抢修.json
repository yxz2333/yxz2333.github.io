              "depth": 1
            }
          ]
        }
      ]
    },
    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "默认全取，有更好的就和反悔堆里最差的替换掉。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tll n; cin >> n;\n\tvar p = vector<pll>(n + 1);\n\tfa(i, 1, n)cin >> p[i].px >> p[i].py;\n\tsort(all1(p), [](const var& a, const var& b)->bool {\n\t\treturn a.py < b.py;\n\t\t});\n\tll now = 0, ans = 0;\n\tvar Q = priority_queue<ll>();\n\tfa(i, 1, n) {\n\t\tconst var& [a, b] = p[i];\n\t\tif (now + a > b) {\n\t\t\tif (Q.top() > a) {\n\t\t\t\t// 交换\n\t\t\t\tnow -= Q.top();\n\t\t\t\tQ.pop();\n\t\t\t\tnow += a;\n\t\t\t\tQ.push(a);\n\t\t\t}\n\t\t}\n\t\telse {\n\t\t\tans++;\n\t\t\tnow += a;\n\t\t\tQ.push(a);\n\t\t}\n\t}\n\tcout << ans << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
