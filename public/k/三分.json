          "heading": "最大值点",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "cpp",
              "code": "int ternary_search_max(int l, int r) {\n\t// 范围 [l, r]\n\twhile (l < r) {\n\t\tint mid = (l + r) / 2;\n\t\tif (f(mid) < f(mid + 1)) {\n\t\t\tl = mid + 1;\n\t\t}\n\t\telse {\n\t\t\tr = mid;\n\t\t}\n\t}\n\treturn l; // 最大值点，最大值 f(l)\n}",
              "depth": 2
            }
          ]
        },
        {
          "heading": "最小值点",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "cpp",
              "code": "int ternary_search_min(int l, int r) {\n\t// 范围 [l, r]\n\twhile (l < r) {\n\t\tint mid = (l + r) / 2;\n\t\tif (f(mid) > f(mid + 1)) {\n\t\t\tl = mid + 1;\n\t\t}\n\t\telse {\n\t\t\tr = mid;\n\t\t}\n\t}\n\treturn l; // 最小值点，最小值 f(l)\n}",
              "depth": 2
            }
          ]
        }
