          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tll n; cin >> n;\n\tconst ll B = sqrt(n);\n\tvar a = vector<ll>(n + 1);\n\tfa(i, 1, n)cin >> a[i];\n \n\tll ans = 0;\n\tfa(val, 1, B) { // 枚举 val => a[j]\n\t\tfa(i, 1, n)if (a[i] < n) { // 枚举 i => a[i]\n\t\t\tll j = i - val * a[i];\n\t\t\tif (j >= 1 and a[j] == val)ans++;\n\t\t\tj = i + val * a[i];\n\t\t\tif (j <= n and a[j] == val)ans++;\n\t\t}\n\t}\n \n\tfa(i, 1, n)if (a[i] > B) { // 枚举 i => a[i]\n\t\tfa(val, 1, n) { // 枚举 val => a[j]\n\t\t\tll j = i + a[i] * val;\n\t\t\tif (j > n)break;\n\t\t\tif (a[j] == val)ans++;\n\t\t}\n\t\tfa(val, 1, n) { // 枚举 val => a[j]\n\t\t\tll j = i - a[i] * val;\n\t\t\tif (j < 1)break;\n\t\t\tif (a[j] == val)ans++;\n\t\t}\n\t}\n \n\tcout << ans / 2 << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
