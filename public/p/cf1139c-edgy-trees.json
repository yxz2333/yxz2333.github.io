    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n, k; cin >> n >> k;\n\tvar s = vector<int>(n + 1);\n\tvar siz = vector<ll>(n + 1);\n\tfa(i, 1, n)s[i] = i, siz[i] = 1;\n\tvar find = [&](var find, int x)->int {\n\t\tif (s[x] == x)return x;\n\t\treturn s[x] = find(find, s[x]);\n\t\t};\n\tfa(i, 1, n - 1) {\n\t\tint u, v, w; cin >> u >> v >> w;\n\t\tif (w == 0) {\n\t\t\tint e1 = find(find, u), e2 = find(find, v);\n\t\t\tif (e1 != e2) {\n\t\t\t\ts[e2] = e1;\n\t\t\t\tsiz[e1] += siz[e2];\n\t\t\t\tsiz[e2] = 0;\n\t\t\t}\n\t\t}\n\t}\n\tll ans = Math::fastPow(n, k, mod);\n\tfa(i, 1, n)ans = ((ans - Math::fastPow(siz[i], k, mod)) % mod + mod) % mod;\n\tcout << ans << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
