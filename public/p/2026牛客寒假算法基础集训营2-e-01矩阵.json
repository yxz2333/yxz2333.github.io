    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n; cin >> n;\n\tvar a = Vec2<int>(n + 1, n + 1);\n\tint now = 0;\n\tfa(i, 1, n) {\n\t\ta[i][i] = now;\n\t\tfa(j, i + 1, n)a[i][j] = now;\n\t\tfa(j, i + 1, n)a[j][i] = now;\n\t\tnow ^= 1;\n\t}\n\tfa(i, 1, n) {\n\t\tfa(j, 1, n)cout << a[i][j];\n\t\tcout << endl;\n\t}\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
