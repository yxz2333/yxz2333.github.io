    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "一个点拆成 3 个，$dis[i][k]$：到 $i$ 点走了 $k = dis_{s,i} \\bmod 3$ 步。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "答案就是 $dis[t][0] \\div 3$。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "struct node {\n\tint id, k, d;\n\tbool operator<(const node& a)const {\n\t\treturn a.d < d;\n\t}\n};\nvoid solve(int CASE)\n{\n\tint n, m; cin >> n >> m;\n\tvar g = Vec3<pii>(n + 1, 3); // 拆点\n\tfa(i, 1, m) {\n\t\tint u, v; cin >> u >> v;\n\t\tfa(j, 0, 2)g[u][j].pb({ v, (j + 1) % 3 });\n\t}\n\tint s, t; cin >> s >> t;\n\tvar dis = Vec2<int>(n + 1, 3, INF);\n\tvar Q = priority_queue<node>();\n\tdis[s][0] = 0;\n\tQ.push({ s,0,dis[s][0] });\n\twhile (Q.size()) {\n\t\tvar[now, k, d] = Q.top();\n\t\tQ.pop();\n\t\tif (d > dis[now][k])continue;\n\t\tfor (var& [to, nk] : g[now][k]) {\n\t\t\tif (dis[to][nk] > dis[now][k] + 1) {\n\t\t\t\tdis[to][nk] = dis[now][k] + 1;\n\t\t\t\tQ.push({ to,nk,dis[to][nk] });\n\t\t\t}\n\t\t}\n\t}\n\tif (dis[t][0] == INF)cout << -1 << endl;\n\telse cout << dis[t][0] / 3 << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
