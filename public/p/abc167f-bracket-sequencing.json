          "type": "p",
          "html": "输入内容由标准输入法提供，格式如下：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "> $N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$S_1$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$:$",
          "depth": 1
