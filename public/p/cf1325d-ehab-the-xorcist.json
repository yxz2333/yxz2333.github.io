          "heading": "样例说明",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "在第一个样例中，$3 \\oplus 1 = 2$，且 $3 + 1 = 4$。不存在更短的有效数组。",
              "depth": 1
            },
