    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "struct node {\n\tint r, ls;\n};\nint vis[505][5005], pre[505][5005];\nvoid solve(int CASE)\n{\n\tint d, s; cin >> d >> s;\n\tfa(i, 0, 500)fa(j, 0, 5000)vis[i][j] = -1;\n\tvar Q = queue<node>();\n\tfa(i, 1, 9)if (s >= i) {\n\t\tpre[i % d][s - i] = 0;\n\t\tvis[i % d][s - i] = i;\n\t\tQ.push({ i % d, s - i });\n\t}\n\twhile (Q.size()) {\n\t\tvar[r, ls] = Q.front();\n\t\tQ.pop();\n\t\tif (r == 0 and ls == 0) {\n\t\t\tstring ans;\n\t\t\tint nowr = 0, nowls = 0;\n\t\t\twhile (nowls != s) {\n\t\t\t\tans.pb('0' + vis[nowr][nowls]);\n\t\t\t\tint nexls = nowls + vis[nowr][nowls];\n\t\t\t\tint nexr = pre[nowr][nowls];\n\t\t\t\tnowr = nexr, nowls = nexls;\n\t\t\t}\n\t\t\treverse(all(ans));\n\t\t\tcout << ans << endl;\n\t\t\treturn;\n\t\t}\n\t\tfa(i, 0, 9)if (ls >= i) {\n\t\t\tint nr = (r * 10 + i) % d;\n\t\t\tint nls = ls - i;\n\t\t\tif (vis[nr][nls] == -1) {\n\t\t\t\tpre[nr][nls] = r;\n\t\t\t\tvis[nr][nls] = i;\n\t\t\t\tQ.push({ nr, nls });\n\t\t\t}\n\t\t}\n\t}\n\tcout << -1 << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
