    },
    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "heading": "核心观察",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "合法区域的边界一定由<strong>圆的圆弧</strong>和<strong>地图边界</strong>构成。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "因此解一定存在于某个圆的圆周附近（紧贴圆外侧）或地图边界上。",
              "depth": 1
            }
          ]
        },
        {
          "heading": "算法思路",
          "level": 3,
          "blocks": [
            {
              "type": "p",
              "html": "对每个圆，在其圆周上等分 <code>SAMPLE_NUM</code> 个采样点（如 400 个）。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "对每个圆周点，计算从圆心指向该点的单位方向向量，将点沿该方向<strong>向外</strong>偏移一个微小量 <code>DELTA</code>（如 <code>1e-5</code>），从而\"挤\"到圆的外部。",
              "depth": 1
            },
            {
              "type": "p",
              "html": "检查偏移后的点：",
              "depth": 1
            },
            {
              "type": "p",
              "html": "是否在地图范围内（$0 \\le x, y \\le l$）",
              "depth": 2
            },
            {
              "type": "p",
              "html": "是否不在任何一个圆的内部（严格在圆外）",
              "depth": 2
            },
            {
              "type": "p",
              "html": "找到满足条件的点后直接输出即可。数据保证一定有解。",
              "depth": 1
            }
          ]
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n, l; cin >> n >> l;\n\tvar p = vector<geo::Circle<db>>(n + 1);\n\tfa(i, 1, n) {\n\t\tint x, y, r; cin >> x >> y >> r;\n\t\tp[i] = { (db)x,(db)y,(db)r };\n\t}\n\tconst int SAMPLE_NUM = 400;\n\tconst db DELTA = 1e-5;\n\tfa(i, 1, n) {\n\t\tvar res = p[i].get_points_on_circle(SAMPLE_NUM);\n\t\tfa(j, 0, vs(res)) {\n\t\t\tvar va = res[j] - p[i].c;\n\t\t\tva = geo::vector_unit(va);\n\t\t\tva = { DELTA * va.x, DELTA * va.y }; // 朝圆心反方向偏移\n\t\t\tres[j] = res[j] + va;\n\t\t}\n\t\tfa(i, 0, vs(res)) {\n\t\t\tif (res[i].x > l or res[i].x < 0 or res[i].y > l or res[i].y < 0)continue;\n\t\t\tbool ok = 1;\n\t\t\tfa(j, 1, n) {\n\t\t\t\tif (geo::point_circle_relation(res[i], p[j]) != 2) {\n\t\t\t\t\t// 点在圆内\n\t\t\t\t\tok = 0;\n\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}\n\t\t\tif (ok) {\n\t\t\t\tcout << fixed << setprecision(12) << res[i].x << \" \" << res[i].y << endl;\n\t\t\t\treturn;\n\t\t\t}\n\t\t}\n\t}\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
