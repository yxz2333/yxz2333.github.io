    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tint n, m; cin >> n >> m;\n\tvar a = Vec2<int>(n + 1, m + 1);\n\tfa(i, 1, n)fa(j, 1, m)cin >> a[i][j];\n\tvar dp = Vec2<int>(n + 1, m + 1, -INF);\n\tfb(i, n, 1)fb(j, m, 1) {\n\t\tif (i == n and j == m)dp[i][j] = a[i][j];\n\t\tif (i != n)dp[i][j] = max(dp[i][j], dp[i + 1][j] + a[i][j]);\n\t\tif (j != m)dp[i][j] = max(dp[i][j], dp[i][j + 1] + a[i][j]);\n\t\tdp[i][j] = min(dp[i][j], 0);\n\t}\n\tif (dp[1][1] <= 0)cout << abs(dp[1][1]) + 1 << endl;\n\telse cout << 0 << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
