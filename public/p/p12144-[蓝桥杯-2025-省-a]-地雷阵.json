        {
          "type": "p",
          "html": "<strong>注：</strong>",
          "depth": 1
        },
        {
          "type": "p",
          "html": "<code>fixed &lt;&lt; setprecision(3)</code>：保留 3 位小数，自带四舍五入。",
          "depth": 2
        },
        {
          "type": "p",
          "html": "<code>round()</code>：小数变整数的四舍五入。",
          "depth": 2
        },
        {
          "type": "p",
          "html": "<code>atan(), atan2()</code>：前者值域 $[-\\frac{\\pi}{2}, \\frac{\\pi}{2}]$；后者值域 $[-\\pi, \\pi]$。",
          "depth": 2
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "const double eps = 1e-9;\nconst double PI = acos(-1.0);\nconst double PI2 = PI / 2.0;\nvoid solve(int CASE)\n{\n\tint n; cin >> n;\n\tvar p = vector<pair<db, db>>(n + 2);\n\tfa(i, 1, n) {\n\t\tint x, y, r; cin >> x >> y >> r;\n\t\tdb now = atan((db)y / x); // atan -> [-PI2, PI2]; atan2 -> [-PI, PI]\n\t\tdb del = asin((db)r / sqrt(x * x + y * y));\n\t\tp[i] = { max(0.0, now - del), min(PI2, now + del) };\n\t}\n\tp[n + 1] = { PI2, PI2 };\n\tsort(all1(p));\n\tdb now = 0, ans = 0;\n\tfa(i, 1, n + 1) {\n\t\tconst var& [l, r] = p[i];\n\t\tif (l > now)ans += l - now;\n\t\tnow = max(now, r);\n\t}\n\tcout << fixed << setprecision(3) << ans / PI2 << endl; // 自带四舍五入；round 是四舍五入到整数\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
