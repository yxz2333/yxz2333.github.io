    {
      "heading": "题解",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "$exgcd$ 板子题，紧扣通解的写法就能做出来。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "void solve(int CASE)\n{\n\tll a, b, c; cin >> a >> b >> c;\n\tll g = Math::gcd(a, b);\n\n\t/* 无解 */\n\tif (c % g != 0) {\n\t\tcout << -1 << endl;\n\t\treturn;\n\t}\n\n\t/* 求特解 */\n\tll x0, y0; // 特解\n\tMath::exgcd(a, b, x0, y0);\n\tx0 *= c / g, y0 *= c / g;\n\n\t/* 求最大最小正整数解 */\n\tll dx = b / g, dy = a / g;\n\n\tll x1 = (x0 % dx + dx) % dx; // x 最小正整数解\n\tif (x1 == 0)x1 += dx; // 如果为 0，加上最小步长\n\tll y2 = (c - a * x1) / b;    // y 最大正整数解\n\n\tll y1 = (y0 % dy + dy) % dy; // y 最小正整数解\n\tif (y1 == 0)y1 += dy; // 如果为 0，加上最小步长\n\tll x2 = (c - b * y1) / a;    // x 最大正整数解\n\n\tif (x2 <= 0 or y2 <= 0) {\n\t\tcout << x1 << ' ' << y1 << endl;\n\t\treturn;\n\t}\n\n\tll cnt = (x2 - x1) / dx + 1; // 正整数解的个数\n\tMT::println(cnt, x1, y1, x2, y2);\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
