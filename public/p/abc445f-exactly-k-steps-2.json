    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "template<const int N>\nclass Matrixmn {\npublic:\n\tarray<array<ll, N + 1>, N + 1> mat;\n\n\tMatrixmn() {\n\t\tfor (int i = 0; i <= N; i++)\n\t\t\tfor (int j = 0; j <= N; j++)\n\t\t\t\tmat[i][j] = 1000000000000000001ll;\n\t}\n\n\tMatrixmn operator* (const Matrixmn& x) {\n\t\t// floyd 求最短路\n\t\tMatrixmn ret;\n\t\tfor (int k = 1; k <= N; k++)\n\t\t\tfor (int i = 1; i <= N; i++) {\n\t\t\t\tif (mat[i][k] == 1000000000000000001ll)continue;\n\t\t\t\tfor (int j = 1; j <= N; j++) {\n\t\t\t\t\tif (x.mat[k][j] == 1000000000000000001ll)continue;\n\t\t\t\t\tret.mat[i][j] = min(ret.mat[i][j], mat[i][k] + x.mat[k][j]);\n\t\t\t\t}\n\t\t\t}\n\t\treturn ret;\n\t}\n\n\tvoid ksm(ll k, Matrixmn base) {\n\t\twhile (k) {\n\t\t\tif (k & 1)*this = *this * base;\n\t\t\tbase = base * base;\n\t\t\tk >>= 1;\n\t\t}\n\t}\n};\nMatrixmn<105> mn, mnbase;\nvoid solve(int CASE)\n{\n\tll n, k; cin >> n >> k;\n\tfa(i, 1, n)fa(j, 1, n) {\n\t\tll d; cin >> d;\n\t\tmn.mat[i][j] = d;\n\t}\n\tmnbase = mn;\n\tmn.ksm(k - 1, mnbase);\n\tfa(i, 1, n)cout << mn.mat[i][i] << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
