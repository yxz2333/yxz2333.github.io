    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "vector<int> ans[N];\nvoid solve(int CASE)\n{\n\tint n; cin >> n;\n\tvar a = vector<int>(n + 1);\n\tfa(i, 1, n)cin >> a[i];\n\tvar tmp = vector<int>();\n\tvar dfs = [&](var dfs, int now, int val)->void {\n\t\tif (now == n + 1 or now == 9) {\n\t\t\tif (tmp.empty())return;\n\t\t\tif (ans[val].size()) {\n\t\t\t\tcout << \"Yes\" << endl;\n\t\t\t\tcout << ans[val].size() << ' ';\n\t\t\t\tfor (int x : ans[val])cout << x << ' ';\n\t\t\t\tcout << endl;\n\t\t\t\tcout << tmp.size() << ' ';\n\t\t\t\tfor (int x : tmp)cout << x << ' ';\n\t\t\t\tcout << endl;\n\t\t\t\texit(0);\n\t\t\t}\n\t\t\tans[val] = tmp;\n\t\t\treturn;\n\t\t}\n\t\tdfs(dfs, now + 1, val);\n\t\ttmp.pb(now);\n\t\tdfs(dfs, now + 1, (val + a[now]) % mod);\n\t\ttmp.pop_back();\n\t\t};\n\tdfs(dfs, 1, 0);\n\tcout << \"No\" << endl;\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
  ],
