  "format": "logseq",
  "sections": [
    {
      "heading": "题目描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "有 $N$ 个人和 $N$ 个桶，编号均为 $1 \\sim N$。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "初始时，第 $i$ 个人手里拿着第 $i$ 号桶（桶是空的）。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "接下来进行 $10^9$ 轮操作，每一轮所有人<strong>同时</strong>进行以下动作：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "1.  第 $i$ 个人往自己手里的桶中加入 <strong>i</strong> 升水。",
          "depth": 2
        },
        {
          "type": "p",
          "html": "2.  把手里的桶传给第 $A_i$ 个人。",
          "depth": 2
        },
        {
          "type": "p",
          "html": "给出 $Q$ 次询问，每次问：在第 $T$ 轮操作结束后，<strong>编号为 B 的那个桶</strong>里一共有多少水？",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输入描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "输入内容由标准输入法提供，格式如下：",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$N$ $Q$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$A_1$ $A_2$ $\\ldots$ $A_N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$T_1$ $B_1$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$T_2$ $B_2$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$\\vdots$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$T_Q$ $B_Q$",
          "depth": 1
        }
      ]
    },
    {
      "heading": "输出描述",
      "level": 2,
      "blocks": [
        {
          "type": "p",
          "html": "输出 $Q$ 行。 $i$ \\-th 行应包含 $i$ \\-th 查询的答案。",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$2 \\leq N \\leq 2 \\times 10^5$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq Q \\leq 2 \\times 10^5$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq A_i \\leq N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq T_i \\leq 10^9$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "$1 \\leq B_i \\leq N$",
          "depth": 1
        },
        {
          "type": "p",
          "html": "所有输入值均为整数。",
          "depth": 1
        }
      ]
    },
    {
      "heading": "样例",
      "level": 2,
      "blocks": [
        {
