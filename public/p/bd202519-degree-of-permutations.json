    {
      "heading": "代码",
      "level": 2,
      "blocks": [
        {
          "type": "code",
          "lang": "cpp",
          "code": "ll a[205], b[205], dp[205][N], fac[205];\nvoid solve(int CASE)\n{\n\tint n; cin >> n;\n\tfac[0] = 1; fa(i, 1, n)fac[i] = fac[i - 1] * i % mod;\n\n\tfa(i, 1, n)cin >> a[i];\n\tint tot = 0;\n\tfa(i, 1, n)cin >> b[i], tot += b[i];\n\n\tdp[0][0] = 1;\n\tfa(i, 1, n) {\n\t\tfb(j, i, 1) fb(k, tot, b[i])\n\t\t\t// 拿了 j 个物品，背包装了 k 体积\n\t\t\tdp[j][k] = (dp[j][k] + dp[j - 1][k - b[i]]) % mod;\n\t}\n\n\tll ans = 0;\n\tfa(i, 1, n) if (a[i] <= tot) {\n\t\t// dp[j][k]：拿了 j 个 b 物品，背包恰好装满 k 体积的方案数\n\t\t// 但是为了算答案，不能拿 b[i] 物品，使用可撤销背包\n\t\tfa(j, 1, n)\n\t\t\tfa(k, b[i], tot)\n\t\t\tdp[j][k] = ((dp[j][k] - dp[j - 1][k - b[i]]) % mod + mod) % mod;\n\n\t\tfa(j, 1, n - 1) \n\t\t\tans = (ans + dp[j][a[i]] * fac[j] % mod * fac[n - 1 - j] % mod) % mod;\n\n\t\tfb(j, n, 1)\n\t\t\tfb(k, tot, b[i])\n\t\t\tdp[j][k] = (dp[j][k] + dp[j - 1][k - b[i]]) % mod;\n\t}\n\tcout << ans << endl;\n\n\t//ll anss = 0;\n\t//var p = vector<int>(n + 1);\n\t//fa(i, 1, n)p[i] = i;\n\t//do {\n\t//\tint pre = 0, now = 0;\n\t//\tfa(i, 1, n) {\n\t//\t\tif (pre == a[p[i]])anss++, now++;\n\t//\t\tpre += b[p[i]];\n\t//\t}\n\t//\t//fa(i, 1, n)cout << a[p[i]] << ' ';\n\t//\t//cout << endl;\n\t//\t//fa(i, 1, n)cout << b[p[i]] << ' ';\n\t//\t//cout << endl;\n\t//\t//if (now)cout << now << endl;\n\t//\t//cout << endl;\n\t//} while (next_permutation(all1(p)));\n\n\t//if (anss != ans) {\n\t//\tdebug(\"NOOOOOOOOOOOOOOOOOOOOOOOOOOOO\");\n\t//\tdebug(ans, anss);\n\t//}\n\treturn;\n}",
          "depth": 1
        }
      ]
    }
