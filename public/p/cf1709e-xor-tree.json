              "type": "code",
              "lang": "",
              "code": "2",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输入 2",
          "level": 3,
          "blocks": [
            {
              "type": "code",
              "lang": "",
              "code": "6\n3 2 1 3 2 1\n4 5\n3 4\n1 4\n2 1\n6 1",
              "depth": 1
            }
          ]
        },
        {
          "heading": "输出 2",
          "level": 3,
          "blocks": [
